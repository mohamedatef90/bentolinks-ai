# BentoLinks AI - Environment Variables Template
# Copy this file to .env.local and fill in your actual API keys

# =====================================================
# REQUIRED: Google Gemini API (for AI link analysis)
# =====================================================
# Get your free API key: https://aistudio.google.com/apikey
# Free tier: 1,500 requests/day, 15 requests/minute
VITE_GEMINI_API_KEY=your_gemini_api_key_here

# =====================================================
# OPTIONAL: Tavily Search API (for real-time news)
# =====================================================
# Get your free API key: https://tavily.com
# Free tier: 1,000 credits/month, basic search = 1 credit
# Note: News feature will be disabled if not provided
VITE_TAVILY_API_KEY=your_tavily_api_key_here

# =====================================================
# OPTIONAL: Supabase (for cloud sync across devices)
# =====================================================
# Create a free project: https://supabase.com
# Get credentials from: Project Settings → API
# Note: Works offline with LocalStorage if not provided
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# =====================================================
# NOTES
# =====================================================
# - All keys starting with VITE_ are exposed to the browser
# - Never commit .env.local to version control
# - For production deployment (Vercel), add these in dashboard:
#   Settings → Environment Variables
# - Minimum required: VITE_GEMINI_API_KEY
# - Without Supabase: Works fully offline with LocalStorage
# - Without Tavily: News section will show empty state
